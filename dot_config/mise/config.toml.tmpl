# vim: set filetype=toml:

[tools]
chezmoi = "latest"
go = { version = "latest", postinstall = "mise run go:setup" }
node = "lts"
pnpm = { version = "latest", postinstall = "mise run pnpm:setup" }
rust = { version = "stable", preinstall = "mise run rust:prepare" }
usage = "latest"

{{- if eq .chezmoi.os "darwin" }}
# node = "lts"
# pnpm = "latest"
{{- end }}

{{- if eq .chezmoi.os "linux" }}
bat = { version = "latest", postinstall = "bat --completion zsh | tee /usr/local/share/zsh/site-functions/_bat" }
eza = "latest"
fzf = "latest"
neovim = { version = "latest", postinstall = "mise run nvim:setup" }
python = "latest"
rg = "latest"
starship = "latest"
zoxide = "latest"

"cargo:erdtree" = "latest"
"cargo:tree-sitter-cli" = { version = "latest", postinstall = "--completions zsh | tee /usr/local/share/zsh/site-functions/_erd" }
{{- end }}

[env]
